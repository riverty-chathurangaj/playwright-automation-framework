# =============================================================================
# pw-testforge-gls — Environment Configuration Template
# Copy to .env and populate with actual values. NEVER commit .env to git.
# =============================================================================

# --- Application Under Test ---
BASE_URL=https://api-dev.internal.riverty.dev
SERVICE_PATH=gl-service
# Valid GLInstance enum values: 1001, 1002, 1003, 1004, 1021-1023, 2001-2004, 2021-2024
INSTANCE_ID=1001
API_VERSION=v1

# --- Environment ---
TEST_ENV=dev
# Options: dev | staging | uat | prod

# --- Authentication (OAuth2 M2M — Client Credentials) ---
# AUTH_BASE_URL     → identity server base URL (token endpoint: {AUTH_BASE_URL}/oauth/token)
# AUTH_CLIENT_ID    → M2M application client ID
# AUTH_CLIENT_SECRET → M2M application client secret
# AUTH_AUDIENCE     → API audience (must be set — omitting it causes the IdP to return an
#                     encrypted JWE instead of a plain JWT, which the API rejects)
AUTH_BASE_URL=https://identity-test.horizonafs.io
AUTH_CLIENT_ID=your-m2m-client-id
AUTH_CLIENT_SECRET=your-m2m-client-secret
AUTH_AUDIENCE=https://api-test.horizonafs.io

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=gl.events
RABBITMQ_DLQ=gl.events.dlq
RABBITMQ_VHOST=/
RABBITMQ_HEARTBEAT=60

# --- Database ---
DB_CLIENT=mssql
# Options: mssql | pg | mysql2
DB_HOST=localhost
DB_PORT=1433
DB_USER=gl_test_user
DB_PASSWORD=your-db-password
DB_NAME=GL_Database
DB_SCHEMA=dbo
# For PostgreSQL: DB_PORT=5432, DB_CLIENT=pg
# For MySQL: DB_PORT=3306, DB_CLIENT=mysql2

# --- AI Integration ---
AI_PROVIDER=azure-openai
# Options: anthropic | openai | azure-openai
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_API_VERSION=2024-12-01-preview
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=4096
AI_ENABLED=false
# Set AI_ENABLED=true to activate AI failure analysis hooks
# For OpenAI: set AI_PROVIDER=openai, OPENAI_API_KEY, and an OpenAI model (e.g. gpt-4o-mini)
# For Azure OpenAI: set AI_PROVIDER=azure-openai, OPENAI_API_KEY, OPENAI_ENDPOINT, and a deployment name as AI_MODEL

# --- Xray Integration ---
XRAY_CLIENT_ID=your-xray-client-id
XRAY_CLIENT_SECRET=your-xray-client-secret
XRAY_BASE_URL=https://xray.cloud.getxray.app
XRAY_PROJECT_KEY=GL
XRAY_EXECUTION_KEY=
# Leave XRAY_EXECUTION_KEY empty to create a new execution per run

# --- Jira Integration (for AI scenario generation) ---
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your-jira-api-token

# --- Logging ---
LOG_LEVEL=info
# Options: error | warn | info | http | verbose | debug | silly
LOG_DIR=reports/logs

# --- Reporting ---
REPORT_DIR=reports
ALLURE_RESULTS_DIR=reports/allure-results

# --- Git (for CI traceability) ---
GIT_SHA=
GIT_BRANCH=
GIT_REPO=

# --- Timeouts (milliseconds) ---
API_TIMEOUT=30000
MESSAGE_WAIT_TIMEOUT=15000
DB_QUERY_TIMEOUT=10000
