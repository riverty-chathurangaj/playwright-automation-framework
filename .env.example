# =============================================================================
# riverty-playwright-bdd — Local Overrides Template
# Copy this file to .env.local for developer-specific secrets and overrides.
# Shared non-secret defaults live in config/environments/<TEST_ENV>.env.
# =============================================================================

# --- Environment selection ---
# Supported now: dev | test | pt
# Example local run:
#   TEST_ENV=dev npm run test:api:smoke
TEST_ENV=dev

# --- Authentication secrets ---
AUTH_CLIENT_ID=your-m2m-client-id
AUTH_CLIENT_SECRET=your-m2m-client-secret

# Optional local overrides for non-secret auth settings
# AUTH_BASE_URL=https://identity-dev.horizonafs.io
# AUTH_AUDIENCE=https://api-dev.horizonafs.io

# --- RabbitMQ secrets / local connection overrides ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Optional non-secret RabbitMQ overrides
# RABBITMQ_EXCHANGE=gl.events
# RABBITMQ_DLQ=gl.events.dlq
# RABBITMQ_VHOST=/
# RABBITMQ_HEARTBEAT=60

# --- Database secrets / local connection overrides ---
# DB secret resolution order in auto mode: mounted files -> Vault -> env vars below
# Set DB_SECRET_SOURCE=env to force the existing DB_USER/DB_PASSWORD flow locally.
DB_SECRET_SOURCE=auto
DB_USER=gl_test_user
DB_PASSWORD=your-db-password
DB_HOST=localhost

# Optional database overrides
# DB_CLIENT=mssql
# DB_PORT=1433
# DB_NAME=GL_Database
# DB_SCHEMA=dbo
# DB_AUTH_TYPE=default

# Optional HashiCorp Vault bootstrap for rotating DB credentials
# VAULT_ADDR=https://vault.example.com
# VAULT_AUTH_PATH=auth/finance/approle/login
# VAULT_ROLE_ID=your-approle-role-id
# VAULT_SECRET_ID=your-approle-secret-id
# VAULT_NAMESPACE=
# VAULT_DB_SECRET_PATH=database/creds/general-ledger-app-role
# VAULT_DB_USERNAME_FIELD=data.username
# VAULT_DB_PASSWORD_FIELD=data.password
# VAULT_TIMEOUT=10000

# --- AI provider secrets ---
# Set only the provider settings you actually use locally.
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# Optional Azure OpenAI overrides
# OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# OPENAI_API_VERSION=2024-12-01-preview
# AI_PROVIDER=azure-openai
# AI_MODEL=gpt-4o-mini
# AI_MAX_TOKENS=4096
# AI_ENABLED=false

# --- Xray secrets ---
XRAY_CLIENT_ID=your-xray-client-id
XRAY_CLIENT_SECRET=your-xray-client-secret

# Optional Xray overrides
# XRAY_BASE_URL=https://xray.cloud.getxray.app
# XRAY_PROJECT_KEY=GL
# XRAY_EXECUTION_KEY=

# --- Jira secrets (AI scenario generation only) ---
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your-jira-api-token

# --- Optional local non-secret overrides ---
# API_BASE_URL=https://api-dev.internal.riverty.dev
# UI_BASE_URL=https://gl-ui-dev.internal.riverty.dev
# UI_AUTH_STORAGE_PATH=.auth/ui-storage-state.json
# UI_DEFAULT_TIMEOUT=10000
# API_SERVICE_PATH=gl-service
# INSTANCE_ID=1001
# API_VERSION=v1
# API_TIMEOUT=30000
# MESSAGE_WAIT_TIMEOUT=15000
# REPORT_DIR=reports
# LOG_LEVEL=info

# --- CI traceability overrides (usually injected by CI) ---
# GIT_SHA=
# GIT_BRANCH=
# GIT_REPO=

# --- UI secrets ---
UI_USERNAME=your-ui-username
UI_PASSWORD=your-ui-password
