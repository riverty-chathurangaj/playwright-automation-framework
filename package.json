{
  "name": "pw-testforge-gls",
  "version": "1.0.0",
  "description": "GL Service API - Intelligent BDD Test Automation Framework",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "bdd:gen": "bddgen",
    "ai:generate": "ts-node -r tsconfig-paths/register src/support/ai-enricher.ts generate",
    "ai:plan": "ts-node -r tsconfig-paths/register src/support/ai-authoring-cli.ts plan",
    "ai:approve": "ts-node -r tsconfig-paths/register src/support/ai-authoring-cli.ts approve",
    "ai:implement": "ts-node -r tsconfig-paths/register src/support/ai-authoring-cli.ts implement",
    "test": "npm run bdd:gen && playwright test",
    "test:ui": "npm run bdd:gen && playwright test --ui",
    "test:smoke": "npm run bdd:gen && playwright test --grep \"@smoke\"",
    "test:security": "npm run bdd:gen && playwright test --project=security",
    "test:transactions": "npm run bdd:gen && playwright test --project=transactions",
    "test:messaging": "npm run bdd:gen && playwright test --project=messaging",
    "test:accounts": "npm run bdd:gen && playwright test --project=accounts",
    "test:clients": "npm run bdd:gen && playwright test --project=clients",
    "test:balance": "npm run bdd:gen && playwright test --project=balance",
    "test:instances": "npm run bdd:gen && playwright test --project=instances",
    "test:accounting-month": "npm run bdd:gen && playwright test --project=accounting-month",
    "test:postings": "npm run bdd:gen && playwright test --project=postings",
    "test:feature": "npm run bdd:gen && playwright test --grep",
    "report:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "report:open": "allure open reports/allure-report",
    "report:serve": "allure serve reports/allure-results",
    "report": "npm run report:generate && npm run report:open",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "test:ai-authoring": "node --test --require ts-node/register/transpile-only --require tsconfig-paths/register tests/ai-authoring.test.ts",
    "clean": "rimraf reports dist .features-gen",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@azure/identity": "^4.13.0",
    "@faker-js/faker": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.4",
    "axios": "^1.13.6",
    "chai": "^5.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "fishery": "^2.2.2",
    "knex": "^3.1.0",
    "mysql2": "^3.11.3",
    "openai": "^6.33.0",
    "pg": "^8.13.0",
    "playwright-bdd": "^8.5.0",
    "tedious": "^18.6.1",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/chai": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "allure-commandline": "^2.30.0",
    "allure-playwright": "^3.6.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
