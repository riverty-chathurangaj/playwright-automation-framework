# Shared non-secret defaults for the pt environment.
# Secrets and any machine-specific overrides belong in .env.local or CI variables.

TEST_ENV=pt
BASE_URL=https://api-pt.internal.riverty.dev
SERVICE_PATH=gl-service
INSTANCE_ID=1001
API_VERSION=v1
API_TIMEOUT=30000
MESSAGE_WAIT_TIMEOUT=15000

AUTH_BASE_URL=https://identity-pt.horizonafs.io
AUTH_AUDIENCE=https://api-pt.horizonafs.io

RABBITMQ_EXCHANGE=gl.events
RABBITMQ_DLQ=gl.events.dlq
RABBITMQ_VHOST=/
RABBITMQ_HEARTBEAT=60

DB_CLIENT=mssql
DB_PORT=1433
DB_NAME=GL_Database
DB_SCHEMA=dbo
DB_QUERY_TIMEOUT=10000
DB_AUTH_TYPE=default

AI_PROVIDER=azure-openai
OPENAI_API_VERSION=2024-12-01-preview
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=4096
AI_ENABLED=false

XRAY_BASE_URL=https://xray.cloud.getxray.app
XRAY_PROJECT_KEY=GL

LOG_LEVEL=info
REPORT_DIR=reports
