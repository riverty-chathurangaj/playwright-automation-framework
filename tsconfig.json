{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@api-core/*": ["src/core/api/*"],
      "@ui-core/*": ["src/core/ui/*"],
      "@shared-core/*": ["src/core/shared/*"],
      "@api-database/*": ["src/core/api/database/*"],
      "@api-messaging/*": ["src/core/api/messaging/*"],
      "@api-utils/*": ["src/core/api/utils/*"],
      "@api-fixtures": ["src/fixtures/api/index.ts"],
      "@api-fixtures/*": ["src/fixtures/api/*"],
      "@ui-fixtures": ["src/fixtures/ui/index.ts"],
      "@ui-fixtures/*": ["src/fixtures/ui/*"],
      "@api-models/*": ["src/models/api/*"],
      "@api-schemas/*": ["src/schemas/api/*"],
      "@ui-pages/*": ["src/pages/ui/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "features/**/*.ts",
    ".features-gen/**/*.ts",
    "playwright.api.config.ts",
    "playwright.ui.config.ts",
    "knexfile.ts",
    ".ai/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "reports"],
  "ts-node": {
    "transpileOnly": true,
    "files": true,
    "esm": false
  }
}
