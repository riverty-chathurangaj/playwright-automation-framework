{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "accounting-month-response",
  "title": "AccountingMonthResponse",
  "description": "Unified response for open/close accounting month — returned for both success (200) and structured error (400/404) responses.",
  "type": "object",
  "properties": {
    "message":    { "type": "string" },
    "instanceId": { "type": "integer" },
    "clientId":   { "type": "integer" },
    "year":       { "type": "integer" },
    "month":      { "type": "integer" }
  },
  "required": ["message", "instanceId", "clientId", "year", "month"],
  "additionalProperties": false
}
