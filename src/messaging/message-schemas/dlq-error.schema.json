{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dlq-error-event",
  "type": "object",
  "description": "Schema for messages found in the Dead Letter Queue",
  "properties": {
    "x-death": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "count":       { "type": "integer", "minimum": 1 },
          "exchange":    { "type": "string" },
          "queue":       { "type": "string" },
          "reason":      { "type": "string", "enum": ["rejected", "expired", "maxlen", "delivery-limit"] },
          "routing-keys": { "type": "array", "items": { "type": "string" } },
          "time":        { "type": "object" }
        }
      }
    },
    "x-first-death-exchange":  { "type": "string" },
    "x-first-death-queue":     { "type": "string" },
    "x-first-death-reason":    { "type": "string" }
  }
}
